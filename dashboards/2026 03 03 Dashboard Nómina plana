                    { name: "Utilidad", valor: plData.utilidad, fill: COLORS.purplishBlue },
                  ]} margin={{ top: 5, right: 10, left: 10, bottom: 5 }}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#f0f0f0" />
                    <XAxis dataKey="name" tick={{ fontSize: 10 }} />
                    <YAxis tick={{ fontSize: 10 }} tickFormatter={v => `$${(v/1000).toFixed(0)}K`} />
                    <Tooltip content={<CustomTooltip />} />
                    <Bar dataKey="valor" radius={[4, 4, 0, 0]}>
                      {[COLORS.success, COLORS.error, COLORS.warning, '#F43F5E', COLORS.purplishBlue].map((c, i) => <Cell key={i} fill={c} />)}
                    </Bar>
                  </BarChart>
                </ResponsiveContainer>
                <p className="text-xs text-gray-400 mt-1 text-center">
                  Nómina = {fmt.percent(plData.nomina / plData.ingresos * 100)} de ingresos | Utilidad = {fmt.percent(plData.utilidad / plData.ingresos * 100)}
                </p>
              </div>
            </div>

            {/* Presupuesto vs Real */}
            <div className="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
              <h3 className="text-sm font-semibold text-gray-700 mb-2">Variación: Nómina Real vs Presupuesto</h3>
              <div className="grid grid-cols-3 gap-4 text-center">
                <div>
                  <p className="text-xs text-gray-500">Nómina NETO Real</p>
                  <p className="text-lg font-bold" style={{ color: COLORS.purplishBlue }}>{fmt.currency(stats.totalNeto)}</p>
                </div>
                <div>
                  <p className="text-xs text-gray-500">Presupuesto Mensual</p>
                  <p className="text-lg font-bold text-gray-700">{fmt.currency(stats.presupuestoNomina)}</p>
                </div>
                <div>
                  <p className="text-xs text-gray-500">Variación</p>
                  <p className={`text-lg font-bold ${stats.totalNeto < stats.presupuestoNomina ? 'text-green-600' : 'text-red-600'}`}>
                    {fmt.currency(stats.totalNeto - stats.presupuestoNomina)}
                  </p>
                  <p className="text-xs text-gray-400">
                    {fmt.percent((stats.totalNeto - stats.presupuestoNomina) / stats.presupuestoNomina * 100)}
                  </p>
                </div>
              </div>
              <p className="text-xs text-gray-400 mt-3 bg-gray-50 p-2 rounded">
                Nota: La nómina NETO real ($721K) es menor al presupuesto ($1.29M) porque el presupuesto incluye costo social patronal, IMSS, RCV, INFONAVIT e ISN que no se reflejan en el neto al empleado.
              </p>
            </div>
          </div>
        )}

        {/* DETALLE TAB */}
        {activeTab === "detalle" && (
          <div className="space-y-3">
            {/* Filters */}
            <div className="flex flex-wrap gap-2 items-center">
              <Filter size={14} className="text-gray-400" />
              <select value={filterArea} onChange={e => setFilterArea(e.target.value)}
                className="text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white">
                <option value="Todos">Todas las áreas</option>
                <option value="Staff">Staff</option>
                <option value="Supervisor">Supervisores</option>
                <option value="Técnico">Técnicos</option>
              </select>
              <select value={filterEntidad} onChange={e => setFilterEntidad(e.target.value)}
                className="text-xs border border-gray-200 rounded-lg px-2 py-1.5 bg-white">
                <option value="Todas">Todas entidades</option>
                <option value="NM">NM Limited</option>
                <option value="MR">MR Coop</option>
              </select>
              <button onClick={() => setShowMinAlert(!showMinAlert)}
                className={`text-xs px-3 py-1.5 rounded-lg border font-medium transition-colors ${
                  showMinAlert ? 'bg-red-50 border-red-200 text-red-700' : 'bg-white border-gray-200 text-gray-600'
                }`}>
                {showMinAlert ? '✕ ' : ''}Bajo mínimo ({stats.underMin.length})
              </button>
              <span className="text-xs text-gray-400 ml-auto">{filteredEmployees.length} registros</span>
            </div>

            {/* Table */}
            <div className="bg-white rounded-xl shadow-sm border border-gray-100 overflow-x-auto">
              <table className="w-full text-xs">
                <thead>
                  <tr style={{ backgroundColor: COLORS.purplishBlue }}>
                    {[
                      { key: "nombre", label: "Nombre" },
                      { key: "puesto", label: "Puesto" },
                      { key: "area", label: "Área" },
                      { key: "entidad", label: "Entidad" },
                      { key: "neto", label: "NETO Real" },
                      { key: "p50", label: "P50 Mercado" },
                      { key: "variacion", label: "Variación" },
                      { key: "status", label: "Status" },
                    ].map(col => (
                      <th key={col.key} className="px-3 py-2.5 text-left text-white font-medium cursor-pointer select-none"
                        onClick={() => {
                          if (col.key === "status" || col.key === "variacion") return;
                          if (sortBy === col.key) setSortDir(d => d === "desc" ? "asc" : "desc");
                          else { setSortBy(col.key); setSortDir("desc"); }
                        }}>
                        <span className="flex items-center gap-1">
                          {col.label}
                          {sortBy === col.key && (sortDir === "desc" ? <ChevronDown size={12} /> : <ChevronUp size={12} />)}
                        </span>
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {filteredEmployees.map((e, i) => {
                    const variacion = ((e.neto - e.p50) / e.p50 * 100);
                    const underMin = e.neto < SALARIO_MINIMO;
                    const overMkt = variacion > 20 && e.puesto !== "CEO";
                    const underMkt = variacion < -10 && e.puesto !== "CEO";
                    let statusColor = COLORS.success;
                    let statusLabel = "OK";
                    if (underMin && e.puesto !== "CEO") { statusColor = COLORS.error; statusLabel = "RIESGO LEGAL"; }
                    else if (underMkt) { statusColor = COLORS.warning; statusLabel = "BAJO MKT"; }
                    else if (overMkt) { statusColor = '#6366F1'; statusLabel = "SOBRE MKT"; }
                    return (
                      <tr key={i} className={`border-b border-gray-50 ${underMin && e.puesto !== "CEO" ? 'bg-red-50' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                        <td className="px-3 py-2 font-medium text-gray-800">{e.nombre}</td>
                        <td className="px-3 py-2 text-gray-600">{e.puesto}</td>
                        <td className="px-3 py-2"><span className={`px-1.5 py-0.5 rounded text-[10px] font-medium ${
                          e.area === 'Staff' ? 'bg-purple-100 text-purple-700' : e.area === 'Supervisor' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600'
                        }`}>{e.area}</span></td>
                        <td className="px-3 py-2 text-gray-500">{e.entidad}</td>
                        <td className="px-3 py-2 font-semibold" style={{ color: underMin ? COLORS.error : COLORS.liberty }}>{fmt.currency(e.neto)}</td>
                        <td className="px-3 py-2 text-gray-500">{fmt.currency(e.p50)}</td>
                        <td className="px-3 py-2">
                          <span className={`font-medium ${variacion >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                            {variacion >= 0 ? '+' : ''}{variacion.toFixed(0)}%
                          </span>
                        </td>
                        <td className="px-3 py-2">
                          <span className="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium" 
                            style={{ backgroundColor: `${statusColor}15`, color: statusColor }}>
                            <span className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: statusColor }}></span>
                            {statusLabel}
                          </span>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {/* MERCADO TAB */}
        {activeTab === "mercado" && (
          <div className="space-y-4">
            <div className="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
              <h3 className="text-sm font-semibold text-gray-700 mb-1">Staff Corporativo: NETO Real vs P50 Mercado</h3>
              <p className="text-xs text-gray-400 mb-3">Excluye CEO (compensación vía utilidades distorsiona la comparación)</p>
              <ResponsiveContainer width="100%" height={300}>
                <BarChart data={marketComparison.sort((a, b) => b.neto - a.neto)} layout="vertical" margin={{ top: 5, right: 30, left: 100, bottom: 5 }}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f0f0f0" />
                  <XAxis type="number" tick={{ fontSize: 10 }} tickFormatter={v => `$${(v/1000).toFixed(0)}K`} />
                  <YAxis type="category" dataKey="nombre" tick={{ fontSize: 10 }} width={95} />
                  <Tooltip content={<CustomTooltip />} />
                  <Bar dataKey="neto" name="NETO Real" fill={COLORS.purplishBlue} radius={[0, 4, 4, 0]} barSize={14} />
                  <Bar dataKey="p50" name="P50 Mercado" fill={COLORS.electricLemonade} radius={[0, 4, 4, 0]} barSize={14} />
                </BarChart>
              </ResponsiveContainer>
            </div>

            {/* Risk Analysis Cards */}
            <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
              <div className="bg-red-50 rounded-xl border border-red-200 p-4">
                <h4 className="text-xs font-bold text-red-700 uppercase mb-2">Riesgo: Bajo Mercado</h4>
                {stats.underMarket.map((e, i) => (
                  <div key={i} className="flex justify-between text-xs py-1 border-b border-red-100 last:border-0">
                    <span className="text-red-800 font-medium">{e.nombre}</span>
                    <span className="text-red-600">{fmt.percent((e.neto - e.p50) / e.p50 * 100)}</span>
                  </div>
                ))}
              </div>
              <div className="bg-purple-50 rounded-xl border border-purple-200 p-4">
                <h4 className="text-xs font-bold text-purple-700 uppercase mb-2">Sobre Mercado (+20%)</h4>
                {stats.overMarket.map((e, i) => (
                  <div key={i} className="flex justify-between text-xs py-1 border-b border-purple-100 last:border-0">
                    <span className="text-purple-800 font-medium">{e.nombre}</span>
                    <span className="text-purple-600">+{fmt.percent((e.neto - e.p50) / e.p50 * 100)}</span>
                  </div>
                ))}
              </div>
              <div className="bg-amber-50 rounded-xl border border-amber-200 p-4">
                <h4 className="text-xs font-bold text-amber-700 uppercase mb-2">Acciones Inmediatas</h4>
                <div className="space-y-2 text-xs text-amber-900">
                  <p><strong>1.</strong> Regularizar Elizabeth + Sandra al mínimo ($9,582)</p>
                  <p><strong>2.</strong> Plan Karen → P50 en 3 trimestres ($33K → $45K)</p>
                  <p><strong>3.</strong> Documentar justificación Mario/Ali como funciones expandidas</p>
                  <p><strong>4.</strong> Tabulador técnicos por célula Q2 2026</p>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* CELULAS TAB */}
        {activeTab === "celulas" && (
          <div className="space-y-4">
            <div className="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
              <h3 className="text-sm font-semibold text-gray-700 mb-3">Peso de Nómina vs Ingresos por Célula</h3>
              <ResponsiveContainer width="100%" height={350}>
                <BarChart data={CELULAS_DATA.sort((a, b) => (b.nomina / b.ingresos) - (a.nomina / a.ingresos))} margin={{ top: 5, right: 10, left: 10, bottom: 60 }}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f0f0f0" />
                  <XAxis dataKey="celula" tick={{ fontSize: 8, angle: -45, textAnchor: 'end' }} interval={0} height={70} />
                  <YAxis tick={{ fontSize: 10 }} tickFormatter={v => `$${(v/1000).toFixed(0)}K`} />
                  <Tooltip content={<CustomTooltip />} />
                  <Bar dataKey="ingresos" name="Ingresos" fill={COLORS.electricLemonade} radius={[3, 3, 0, 0]} />
                  <Bar dataKey="nomina" name="Nómina" fill={COLORS.purplishBlue} radius={[3, 3, 0, 0]} />
                  <Bar dataKey="utilidad" name="Utilidad" fill={COLORS.success} radius={[3, 3, 0, 0]} />
                  <Legend wrapperStyle={{ fontSize: '11px' }} />
                </BarChart>
              </ResponsiveContainer>
            </div>

            {/* Cell detail table */}
            <div className="bg-white rounded-xl shadow-sm border border-gray-100 overflow-x-auto">
              <table className="w-full text-xs">
                <thead>
                  <tr style={{ backgroundColor: COLORS.purplishBlue }}>
                    {["Célula", "Ingresos", "Nómina", "Supervisión", "Gastos", "Utilidad", "Margen", "Nómina/Ingreso"].map(h => (
                      <th key={h} className="px-3 py-2.5 text-left text-white font-medium">{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {CELULAS_DATA.sort((a, b) => (b.utilidad / b.ingresos) - (a.utilidad / a.ingresos)).map((c, i) => {
                    const margen = (c.utilidad / c.ingresos * 100);
                    const nomPct = (c.nomina / c.ingresos * 100);
                    return (
                      <tr key={i} className={`border-b border-gray-50 ${c.utilidad < 0 ? 'bg-red-50' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                        <td className="px-3 py-2 font-medium text-gray-800">{c.celula}</td>
                        <td className="px-3 py-2 text-gray-700">{fmt.currency(c.ingresos)}</td>
                        <td className="px-3 py-2 text-gray-700">{fmt.currency(c.nomina)}</td>
                        <td className="px-3 py-2 text-gray-500">{fmt.currency(c.supervision)}</td>
                        <td className="px-3 py-2 text-gray-500">{fmt.currency(c.gastos)}</td>
                        <td className="px-3 py-2 font-semibold" style={{ color: c.utilidad >= 0 ? COLORS.success : COLORS.error }}>{fmt.currency(c.utilidad)}</td>
                        <td className="px-3 py-2">
                          <span className={`font-medium ${margen >= 50 ? 'text-green-600' : margen >= 30 ? 'text-amber-600' : 'text-red-600'}`}>
                            {fmt.percent(margen)}
                          </span>
                        </td>
                        <td className="px-3 py-2">
                          <div className="flex items-center gap-1">
                            <div className="w-12 bg-gray-100 rounded-full h-1.5">
                              <div className="h-1.5 rounded-full" style={{ 
                                width: `${Math.min(nomPct, 100)}%`, 
                                backgroundColor: nomPct > 80 ? COLORS.error : nomPct > 50 ? COLORS.warning : COLORS.success 
                              }}></div>
                            </div>
                            <span className="text-gray-500">{fmt.percent(nomPct)}</span>
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                  {/* Totals */}
                  <tr className="border-t-2 border-gray-300 font-bold bg-gray-50">
                    <td className="px-3 py-2.5 text-gray-800">TOTAL</td>
                    <td className="px-3 py-2.5">{fmt.currency(CELULAS_DATA.reduce((s, c) => s + c.ingresos, 0))}</td>
                    <td className="px-3 py-2.5">{fmt.currency(CELULAS_DATA.reduce((s, c) => s + c.nomina, 0))}</td>
                    <td className="px-3 py-2.5">{fmt.currency(CELULAS_DATA.reduce((s, c) => s + c.supervision, 0))}</td>
                    <td className="px-3 py-2.5">{fmt.currency(CELULAS_DATA.reduce((s, c) => s + c.gastos, 0))}</td>
                    <td className="px-3 py-2.5" style={{ color: COLORS.success }}>{fmt.currency(CELULAS_DATA.reduce((s, c) => s + c.utilidad, 0))}</td>
                    <td className="px-3 py-2.5">{fmt.percent(CELULAS_DATA.reduce((s, c) => s + c.utilidad, 0) / CELULAS_DATA.reduce((s, c) => s + c.ingresos, 0) * 100)}</td>
                    <td className="px-3 py-2.5">{fmt.percent(CELULAS_DATA.reduce((s, c) => s + c.nomina, 0) / CELULAS_DATA.reduce((s, c) => s + c.ingresos, 0) * 100)}</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

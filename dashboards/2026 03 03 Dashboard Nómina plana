          {p.name}: {fmt.currency(p.value)}
        </p>
      ))}
    </div>
  );
};

export default function NominaDashboard() {
  const [activeTab, setActiveTab] = useState("resumen");
  const [filterArea, setFilterArea] = useState("Todos");
  const [filterEntidad, setFilterEntidad] = useState("Todas");
  const [sortBy, setSortBy] = useState("neto");
  const [sortDir, setSortDir] = useState("desc");
  const [showMinAlert, setShowMinAlert] = useState(false);

  const filteredEmployees = useMemo(() => {
    let data = ALL_EMPLOYEES;
    if (filterArea !== "Todos") data = data.filter(e => e.area === filterArea);
    if (filterEntidad !== "Todas") data = data.filter(e => e.entidad === filterEntidad);
    if (showMinAlert) data = data.filter(e => e.neto < SALARIO_MINIMO);
    return [...data].sort((a, b) => sortDir === "desc" ? b[sortBy] - a[sortBy] : a[sortBy] - b[sortBy]);
  }, [filterArea, filterEntidad, sortBy, sortDir, showMinAlert]);

  const stats = useMemo(() => {
    const all = ALL_EMPLOYEES;
    const totalNeto = all.reduce((s, e) => s + e.neto, 0);
    const underMin = all.filter(e => e.neto < SALARIO_MINIMO);
    const overMarket = all.filter(e => e.neto > e.p50 * 1.2 && e.puesto !== "CEO");
    const underMarket = all.filter(e => e.neto < e.p50 * 0.9 && e.puesto !== "CEO");
    const nmCount = all.filter(e => e.entidad === "NM").length;
    const mrCount = all.filter(e => e.entidad === "MR").length;
    const avgNeto = totalNeto / all.length;
    const presupuestoNomina = 1286215; // From P&L
    const costoAjusteMin = underMin.reduce((s, e) => s + Math.max(0, SALARIO_MINIMO - e.neto), 0);
    return { totalNeto, underMin, overMarket, underMarket, nmCount, mrCount, avgNeto, presupuestoNomina, costoAjusteMin, total: all.length };
  }, []);

  // Distribution by area
  const areaDistribution = useMemo(() => {
    const areas = {};
    ALL_EMPLOYEES.forEach(e => {
      if (!areas[e.area]) areas[e.area] = { area: e.area, count: 0, totalNeto: 0 };
      areas[e.area].count++;
      areas[e.area].totalNeto += e.neto;
    });
    return Object.values(areas);
  }, []);

  // Market comparison scatter data
  const marketComparison = useMemo(() => {
    return STAFF.filter(e => e.puesto !== "CEO").map(e => ({
      ...e,
      variacion: ((e.neto - e.p50) / e.p50 * 100),
    }));
  }, []);

  // P&L data
  const plData = {
    ingresos: 2530089,
    nomina: 1286215,
    compras: 209179,
    gastosAdmin: 520837,
    gastosFinancieros: 25000,
    utilidad: 488858,
  };

  const tabs = [
    { id: "resumen", label: "Resumen Ejecutivo" },
    { id: "detalle", label: "Detalle Nómina" },
    { id: "mercado", label: "vs. Mercado" },
    { id: "celulas", label: "Costo por Célula" },
  ];

  return (
    <div className="min-h-screen" style={{ backgroundColor: COLORS.whiteSmoke, fontFamily: 'Inter, system-ui, sans-serif' }}>
      {/* Header */}
      <div className="px-6 py-4" style={{ backgroundColor: COLORS.liberty }}>
        <div className="flex items-center justify-between">
          <div>
            <h1 className="text-lg font-bold text-white">Análisis de Nómina Q360</h1>
            <p className="text-xs" style={{ color: COLORS.electricLemonade }}>Base: Quincena Sept 2025 | 59 empleados registrados | Presupuesto 2026</p>
          </div>
          <div className="text-right">
            <p className="text-xs text-gray-400">Nómina NETO mensual</p>
            <p className="text-xl font-bold text-white">{fmt.currency(stats.totalNeto)}</p>
          </div>
        </div>
        {/* Tabs */}
        <div className="flex gap-1 mt-3">
          {tabs.map(t => (
            <button key={t.id} onClick={() => setActiveTab(t.id)}
              className={`px-3 py-1.5 rounded-md text-xs font-medium transition-colors ${
                activeTab === t.id ? 'text-white' : 'text-gray-400 hover:text-gray-200'
              }`}
              style={activeTab === t.id ? { backgroundColor: COLORS.purplishBlue } : {}}>
              {t.label}
            </button>
          ))}
        </div>
      </div>

      <div className="p-4 max-w-full">
        {/* RESUMEN TAB */}
        {activeTab === "resumen" && (
          <div className="space-y-4">
            {/* KPI Cards */}
            <div className="grid grid-cols-2 lg:grid-cols-4 gap-3">
              <SummaryCard title="Total Empleados" value={stats.total} subtitle={`NM: ${stats.nmCount} | MR: ${stats.mrCount}`} icon={Users} color={COLORS.purplishBlue} />
              <SummaryCard title="Neto Mensual Total" value={fmt.currency(stats.totalNeto)} subtitle={`Presupuesto: ${fmt.currency(stats.presupuestoNomina)}`} icon={DollarSign} color={COLORS.purplishBlue} />
              <SummaryCard title="Promedio NETO" value={fmt.currency(stats.avgNeto)} subtitle="Por empleado" icon={TrendingUp} color={COLORS.info} />
              <SummaryCard title="Bajo Mínimo Legal" value={`${stats.underMin.length} empleados`} subtitle={`Costo ajuste: ${fmt.currency(stats.costoAjusteMin)}/mes`} icon={AlertTriangle} color={COLORS.error} alert={true} />

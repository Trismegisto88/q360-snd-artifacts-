    },
    {
      nombre: "Jazmín Olivares", puesto: "Gte Tesorería/SAC", base: 40000,
      streams: [
        { tipo: "Pólizas (primaria)", desc: "3% valor mensual nuevas pólizas — BAT-CUAUT activa, Transfers, Litio. Si participa supervisor: 2% Jaz + 1% Sup", rate: 0.03, revenue: pol, monto: pol * 0.025 },
        { tipo: "Correctivos BAT", desc: "1% coordinación comercial WM (shared con Jaime)", rate: 0.01, revenue: corrBAT, monto: corrBAT * 0.01 },
        { tipo: "Correctivos MrCoop", desc: "1% coordinación (shared con Jorge)", rate: 0.01, revenue: corrMRCOOP, monto: corrMRCOOP * 0.01 },
        { tipo: "Refacciones", desc: "2% margen refacciones BAT+MrCoop que cierra", rate: 0.02, revenue: (refBAT+refMRCOOP)*margenRef, monto: (refBAT+refMRCOOP)*margenRef*0.02 },
      ],
      nota: "Vendedora primaria de pólizas. BAT-CUAUT ya activa. Pipeline: Transfers 9 CEDIS + Litio 7 CEDIS. Bono trimestral adicional $5K.",
      riesgo: "clave",
    },
    {
      nombre: "Thalía Ortiz", puesto: "Coord CxC & SAC", base: 19115,
      streams: [
        { tipo: "Montas correctivos", desc: "30% ejecutor del 4% pool (factura y cobra)", rate: null, revenue: corrMONTA, monto: corrMONTA * 0.04 * 0.30 },

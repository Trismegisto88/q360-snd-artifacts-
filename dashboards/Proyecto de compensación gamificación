export default function Q360CompV2() {
  const [tab, setTab] = useState('comisiones');
  const [sc, setSc] = useState('base');
  const [expandedPerson, setExpandedPerson] = useState(null);

  const scenario = SC[sc];
  const people = useMemo(() => calcCommissions(scenario), [sc]);
  const totalAdditionalRev = scenario.correctivos + scenario.polizasNuevas + scenario.refacciones;
  const totalCommPool = people.reduce((s, p) => s + p.totalCom, 0);
  const totalCompMes = people.reduce((s, p) => s + p.compTotal, 0);

  // Ramp-up data by month (12 months)
  const monthlyRamp = useMemo(() => {
    const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    return months.map((m, i) => {
      const rampFactor = Math.min(1, (i + 1) / scenario.rampMonth);
      const corrRamp = i < 2 ? scenario.correctivos * 0.7 : scenario.correctivos * Math.min(1, 0.7 + 0.3 * ((i-1) / 6));
      const polRamp = i < 2 ? 0 : scenario.polizasNuevas * rampFactor * 0.7;
      const refRamp = i < 3 ? scenario.refacciones * 0.3 : scenario.refacciones * rampFactor * 0.8;
      return { mes: m, correctivos: Math.round(corrRamp), polizas: Math.round(polRamp), refacciones: Math.round(refRamp), total: Math.round(corrRamp + polRamp + refRamp) };
    });
  }, [sc]);

  const annualRevAdditional = monthlyRamp.reduce((s, m) => s + m.total, 0);

  const tabs = [
    { key: 'comisiones', label: 'Comisiones Individuales', icon: <DollarSign size={14}/> },
    { key: 'streams', label: '3 Revenue Streams', icon: <TrendingUp size={14}/> },
    { key: 'gamificacion', label: 'Sistema Gamificado', icon: <Gamepad2 size={14}/> },
    { key: 'roadmap', label: 'Próximos Pasos', icon: <Target size={14}/> },
  ];

  return (
    <div className="min-h-screen" style={{ background: C.smoke, fontFamily: 'system-ui, sans-serif' }}>
      {/* Header */}
      <div className="px-6 py-4" style={{ background: C.liberty }}>
        <div className="max-w-7xl mx-auto">
          <div className="flex items-center justify-between">
            <div>
              <h1 className="text-lg font-bold text-white">Q360 — Proyección Compensación + Gamificación 2026 v2</h1>
              <p style={{ color: C.cyan }} className="text-xs mt-0.5">3 Revenue Streams: Correctivos + Pólizas Nuevas + Refacciones | Comisiones individuales + Sistema gamificado</p>
            </div>
            <div className="flex gap-2">
              {Object.entries(SC).map(([k, v]) => (
                <button key={k} onClick={() => setSc(k)}
                  className={`px-3 py-1.5 rounded-lg text-xs font-semibold transition-all ${sc === k ? 'text-white shadow-lg' : 'text-gray-400 hover:text-white'}`}
                  style={{ background: sc === k ? v.color : 'transparent', border: sc === k ? 'none' : '1px solid rgba(255,255,255,0.15)' }}>
                  {v.label}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>

      {/* Tabs */}
      <div className="border-b border-gray-200 bg-white">
        <div className="max-w-7xl mx-auto px-6 flex gap-1">
          {tabs.map(t => (
            <button key={t.key} onClick={() => setTab(t.key)}
              className={`flex items-center gap-1.5 px-4 py-3 text-xs font-medium border-b-2 transition-colors ${tab === t.key ? 'border-[#4814DA] text-[#4814DA]' : 'border-transparent text-gray-500 hover:text-gray-700'}`}>
              {t.icon}{t.label}
            </button>
          ))}
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-6 py-5">

        {/* ═══ TAB: COMISIONES INDIVIDUALES ═══ */}
        {tab === 'comisiones' && (
          <div className="space-y-5">
            {/* KPI Cards */}
            <div className="grid grid-cols-2 md:grid-cols-5 gap-3">
              <Kpi icon={<TrendingUp size={16}/>} title="REVENUE ADICIONAL /MES" value={fmt.c(totalAdditionalRev)} sub={`Anual estimado: ${fmt.c(annualRevAdditional)}`} color={C.green} />
              <Kpi icon={<DollarSign size={16}/>} title="POOL COMISIONES /MES" value={fmt.c(totalCommPool)} sub={`${fmt.p(totalCommPool/totalAdditionalRev*100)} del revenue adicional`} color={C.purple} />
              <Kpi icon={<Users size={16}/>} title="COMP TOTAL 6 PERSONAS" value={fmt.c(totalCompMes)} sub={`Base + Variable combinado`} color={C.slate} />
              <Kpi icon={<Award size={16}/>} title="MARGEN PROM POOL" value={fmt.p((scenario.margenCorr*0.4+scenario.margenPol*0.3+scenario.margenRef*0.3)*100)} sub="Ponderado 3 streams" color={C.amber} />

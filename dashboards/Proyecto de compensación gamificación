                                <td className="py-1.5 text-right font-mono font-bold" style={{ color: C.purple }}>{fmt.c(p.totalCom)}</td>
                              </tr>
                            </tfoot>
                          </table>
                        </div>
                        {/* Notes */}
                        <div className="bg-white rounded-lg p-3 border border-gray-200">
                          <p className="text-xs font-semibold text-gray-600 mb-1">Notas y Contexto</p>
                          <p className="text-[11px] text-gray-600 leading-relaxed">{p.nota}</p>

      ],
      nota: "Eliminar tope $3K — uncapped combinado. 30 técnicos generan volumen. Su inventario Litio/Transfers es bloqueador de pólizas.",
      riesgo: "precaucion",
    },
    {
      nombre: "Gersom García", puesto: "Sup UN Montacargas", base: 16950,
      streams: [
        { tipo: "Correctivos Montas cerrador", desc: "40% del 4% pool — venta dual campo + Thalía teléfono", rate: null, revenue: corrMONTA, monto: corrMONTA * 0.04 * 0.40 },
        { tipo: "Refacciones Montas", desc: "3% margen — Kits Crown, llantas, frenos, hidráulico (50/50 con Thalía si aplica)", rate: 0.03, revenue: refMONTA*margenRef, monto: refMONTA*margenRef*0.03*0.60 },
      ],
      nota: "Modelo venta dual más maduro. Estacionalidad H2 fuerte (Ago-Dic). Kits Crown $174K invertidos = pipeline listo. Sin tope.",

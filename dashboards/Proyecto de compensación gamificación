  ];

  return people.map(p => {
    const totalCom = p.streams.reduce((s, st) => s + st.monto, 0);
    const compTotal = p.base + totalCom;
    const compAnual = compTotal * 12;
    const pctVariable = totalCom / compTotal * 100;
    return { ...p, totalCom, compTotal, compAnual, pctVariable };
  });
}


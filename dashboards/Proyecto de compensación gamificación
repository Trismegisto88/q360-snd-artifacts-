        { tipo: "Carritos (nueva línea)", desc: "2% venta póliza nueva de carritos", rate: 0.02, revenue: 50000, monto: 50000 * 0.02 },
      ],
      nota: "Clave O2C: su velocidad de facturación determina cash flow. Venta telefónica complementa a Gersom en campo. Carritos = nueva línea a explorar.",
      riesgo: "ok",
    },
    {
      nombre: "Jaime González", puesto: "Sup UN Baterías", base: 16950,
      streams: [
        { tipo: "Correctivos BAT cerrador", desc: "40% del 4% pool — cierra venta con gerente WM en CEDIS", rate: null, revenue: corrBAT, monto: corrBAT * 0.04 * 0.40 },
        { tipo: "Pólizas asistencia", desc: "1% cuando hay evidencia de contribución (shared de Jazmín)", rate: 0.01, revenue: pol*0.6, monto: pol * 0.6 * 0.01 },

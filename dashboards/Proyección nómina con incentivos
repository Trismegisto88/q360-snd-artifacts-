      let bonoMensualEst = 0;
      if (s.bonoTrim > 0) {
        const pago = s.bonoTrim * sc.bonoStaffPct;
        bonoMensualEst = pago / 3;
      }
      let comMensualEst = 0;
      if (s.comMax > 0) {
        // Supervisors: based on correctivos revenue
        if (s.area === "Supervisor") {
          comMensualEst = s.comMax * (sc.correctivosMes / 350000);
        } else if (s.comTipo.includes("ejecutor")) {
          // Thalía: 30% of 4% of correctivos
          comMensualEst = sc.correctivosMes * 0.04 * 0.30;
        }
      }
      const compTotalMes = s.baseReal + bonoMensualEst + comMensualEst;
      const compTotalAnual = compTotalMes * 12;
      return { ...s, bonoMensualEst, comMensualEst, compTotalMes, compTotalAnual };
    });

    // Tech commissions
    const comTechPorDeteccion = sc.correctivosMes * sc.comPctTech * 0.30; // 30% detector pool
    const comPorTecnico = comTechPorDeteccion / totalTechs;
    
    const techProjections = techGroups.map(g => {
      const comMes = comPorTecnico * g.headcount;
      const baseTotalMes = g.baseEst * g.headcount;
      const totalMes = baseTotalMes + comMes;
      return { ...g, comMes, baseTotalMes, totalMes, comPorPersona: comPorTecnico };
    });

    const techTotalBase = techProjections.reduce((s, g) => s + g.baseTotalMes, 0);
    const techTotalCom = techProjections.reduce((s, g) => s + g.comMes, 0);
    const techTotal = techTotalBase + techTotalCom;

    const staffTotalBase = staffWithProjections.reduce((s, p) => s + p.baseReal, 0);
    const staffTotalBono = staffWithProjections.reduce((s, p) => s + p.bonoMensualEst, 0);
    const staffTotalCom = staffWithProjections.reduce((s, p) => s + p.comMensualEst, 0);
    const staffTotal = staffTotalBase + staffTotalBono + staffTotalCom;

    const grandTotalMes = staffTotal + techTotal;
    const grandTotalAnual = grandTotalMes * 12;

    // Costs for legal adjustments
    const legalAdjustment = (9582 - 9206) + (9582 - 8235); // Elizabeth + Sandra
    
    // Revenue context
    const revenueBase = 2530089; // monthly from P&L
    const correctivosExtra = sc.correctivosMes;
    const totalRevenue = revenueBase + correctivosExtra;
    const nomPctRevenue = grandTotalMes / totalRevenue * 100;

    return {
      staff: staffWithProjections,
      techs: techProjections,
      techTotalBase, techTotalCom, techTotal,
      staffTotalBase, staffTotalBono, staffTotalCom, staffTotal,
      grandTotalMes, grandTotalAnual,
      legalAdjustment,
      revenueBase, correctivosExtra, totalRevenue, nomPctRevenue,
      revenueCorrectivos: sc.correctivosMes,
      comTotalCorrectivos: sc.correctivosMes * sc.comPctTech,
      roiIncentivos: sc.correctivosMes / (staffTotalBono + staffTotalCom + techTotalCom),

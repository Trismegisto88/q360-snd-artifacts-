function Card({ icon, title, value, subtitle, color = '#475569' }) {
  return (
    <div className="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
      <div className="flex items-center gap-2 mb-2">
        <span className="text-gray-400">{icon}</span>
        <p className="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">{title}</p>
      </div>
      <p className="text-xl font-bold" style={{ color }}>{value}</p>
      {subtitle && <p className="text-[10px] text-gray-400 mt-1">{subtitle}</p>}
    </div>
  );
}

function Row({ label, m, total, color }) {
  return (
    <tr className="border-b border-gray-100">
      <td className="py-2 px-3 text-gray-700">
        {color && <span className="inline-block w-2.5 h-2.5 rounded-full mr-2" style={{ background: color }}></span>}
        {label}
      </td>
      <td className="py-2 px-3 text-right font-mono">{fmt.c(m)}</td>
      <td className="py-2 px-3 text-right font-mono text-gray-500">{fmt.c(m * 12)}</td>
      <td className="py-2 px-3 text-right font-mono text-gray-500">{((m / total) * 100).toFixed(1)}%</td>
    </tr>
  );
}
